{
  "name": "desktop-todo-widget",
  "version": "0.1.0",
  "private": true,
  "description": "A quiet Windows desktop Todo widget inspired by Reminders.",
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder --win portable",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0"
  },
  "build": {
    "appId": "com.ghhostttt.todo",
    "productName": "Desktop Todo Widget",
    "compression": "store",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "asarUnpack": [
      "node_modules/koffi/**/*"
    ],
    "win": {
      "icon": "assets/icons/todo-tray.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    }
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "koffi": "^3.1.1",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "9.31.0",
    "@types/node": "^22.16.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^37.2.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "3.1.0",
    "eslint": "9.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.38.0",
    "vite": "6.1.0",
    "vitest": "^3.2.4"
  }
}
